# ============================================
# Indoor Management System — Production Config
# ============================================
# Copy this file to .env and fill in values
# before running: docker compose -f docker-compose.prod.yml up -d --build

# App port (what port to expose on the VPS)
APP_PORT=80

# MySQL
DB_NAME=indoor_sports_db
DB_USER=root
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Server
PORT=5000
NODE_ENV=production
CLIENT_URL=http://your-domain.com
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_STRING_HERE
JWT_EXPIRES_IN=7d

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
