          "response": []
        },
        {
          "name": "Create Time Slot (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dayOfWeek\": -1,\n  \"startTime\": \"22:00\",\n  \"endTime\": \"23:00\",\n  \"isActive\": true,\n  \"rateType\": \"night\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/slots",
              "host": ["{{baseUrl}}"],
              "path": ["slots"]
            },
            "description": "Add a new slot. dayOfWeek: -1 (all days default), 0-6 (Sun-Sat), or use specificDate for a one-off override."
          },
          "response": []
        },
        {
          "name": "Update Time Slot (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/slots/:id",
              "host": ["{{baseUrl}}"],
              "path": ["slots", ":id"],
              "variable": [
                { "key": "id", "value": "1" }
              ]
            },
            "description": "Toggle slot active/inactive or modify time parameters."
          },
          "response": []
        },
        {
          "name": "Delete Time Slot (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/slots/:id",
              "host": ["{{baseUrl}}"],
              "path": ["slots", ":id"],
              "variable": [
                { "key": "id", "value": "15" }
              ]
            },
            "description": "Permanently remove a slot from the schedule."
          },
          "response": []
        }
      ]
    },
