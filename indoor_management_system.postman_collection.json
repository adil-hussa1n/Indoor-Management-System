{
  "info": {
    "_postman_id": "bfd8bb1d-5573-4f9e-be41-01f6874eb78d",
    "name": "Indoor Management System API (MySQL)",
    "description": "Comprehensive Postman collection for testing the Indoor Sports Management & Booking System.\n\nDatabase: MySQL 8.0 + Sequelize ORM\nIDs: Auto-increment integers (not MongoDB ObjectIds)\n\nUsage:\n1. Run 'Admin Login' first — the token is automatically saved to {{adminToken}}.\n2. All admin endpoints inherit Bearer auth from the collection.\n3. Replace :id path variables with actual integer IDs from your database.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Server health check — verifies MySQL database connectivity, uptime, and API version."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set('adminToken', jsonData.token);",
                  "  console.log('Token saved to {{adminToken}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"adminpassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate as admin. The JWT token is automatically extracted and saved to {{adminToken}} for subsequent requests."
          },
          "response": []
        },
        {
          "name": "Get Admin Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Retrieve the currently authenticated admin's profile."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Public Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"John Doe\",\n  \"phone\": \"+8801700000000\",\n  \"email\": \"johndoe@example.com\",\n  \"sport\": \"Football\",\n  \"bookingDate\": \"2026-07-10\",\n  \"startTime\": \"10:00\",\n  \"endTime\": \"11:00\",\n  \"duration\": 1,\n  \"players\": 10,\n  \"notes\": \"Please provide a tournament ball.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": ["{{baseUrl}}"],
              "path": ["booking"]
            },
            "description": "Submit a public booking reservation. Price is auto-calculated from settings. Status defaults to 'Pending'."
          },
          "response": []
        },
        {
          "name": "Get Dashboard Data (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard"]
            },
            "description": "Dashboard overview — total bookings, revenue, peak slots, and occupancy rates."
          },
          "response": []
        },
        {
          "name": "Get Bookings List (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings?status=Pending&sport=Football",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"],
              "query": [
                { "key": "status", "value": "Pending" },
                { "key": "sport", "value": "Football" }
              ]
            },
            "description": "List all bookings with optional filters (status, sport, search, date range)."
          },
          "response": []
        },
        {
          "name": "Create Manual Booking (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Walk-in Guest\",\n  \"phone\": \"+8801800000000\",\n  \"email\": \"walkin@example.com\",\n  \"sport\": \"Basketball\",\n  \"bookingDate\": \"2026-07-15\",\n  \"startTime\": \"18:00\",\n  \"endTime\": \"19:00\",\n  \"duration\": 1,\n  \"players\": 10,\n  \"notes\": \"Cash booking on site.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            },
            "description": "Book a slot manually for a walk-in guest. Auto-confirmed by admin."
          },
          "response": []
        },
        {
          "name": "Get Booking Details (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/:id",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", ":id"],
              "variable": [
                { "key": "id", "value": "1", "description": "MySQL auto-increment booking ID" }
              ]
            },
            "description": "Fetch full details of a specific booking by its integer ID."
          },
          "response": []
        },
        {
          "name": "Update Booking (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Johnathan Doe\",\n  \"phone\": \"+8801799999999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings/:id",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", ":id"],
              "variable": [
                { "key": "id", "value": "1" }
              ]
            },
            "description": "Update customer details on a booking. Uses optimistic locking (version column)."
          },
          "response": []
        },
        {
          "name": "Update Booking Status (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Confirmed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking-status/:id",
              "host": ["{{baseUrl}}"],
              "path": ["booking-status", ":id"],
              "variable": [
                { "key": "id", "value": "1" }
              ]
            },
            "description": "Change booking status: Pending → Confirmed → Completed or Cancelled. Creates a BookingStatusHistory record."
          },
          "response": []
        },
        {
          "name": "Delete Booking (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/:id",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", ":id"],
              "variable": [
                { "key": "id", "value": "1" }
              ]
            },
            "description": "Soft-delete a booking (paranoid mode — recoverable via database)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Slots & Availability",
      "item": [
        {
          "name": "Get Available Slots (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/available-slots?date=2026-07-10",
